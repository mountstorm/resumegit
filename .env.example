# Real mode: GPT-5.6 via the OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Mock mode: run the full app without an API key (deterministic AI stand-in).
# Set to 1 to force; mock is also used automatically when no key is present.
MOCK_AI=

# Where resume git repositories live (default: ./data/repo)
RESUMEGIT_DATA=